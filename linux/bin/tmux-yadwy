#!/bin/bash

SESSIONNAME="yadwy"
BACK_PATH=~/myp/yadwy-backend-go

function send-command() {
  tmux send-keys -t "$SESSIONNAME" "$1" C-m
}

if ! tmux has-session -t "$SESSIONNAME" &> /dev/null
then
  # new session, default window for frontend
  tmux new-session -s "$SESSIONNAME" -n backend -c "$BACK_PATH" -d
  tmux split-window -v -p 50 "$@"
  send-command "docker compose up"

  # lazygit window
  # tmux new-window -n lazygit -t "$SESSIONNAME" -c "$BACK_PATH"
  # send-command "lazygit"

  # go back to the frontend window
  tmux select-window -t "$SESSIONNAME":backend
  tmux select-pane -t "$SESSIONNAME":backend.1
  send-command "make run"
fi

tmux attach -t "$SESSIONNAME"
